# Copy to .env for local runtime. Do not commit real values.
# Runtime integrations are limited to Azure DevOps, Microsoft Teams, and Purview.
# Fabric/Azure platform actions are performed by a human outside these agents.

# Azure DevOps board access
ADO_ORGANIZATION_URL=
ADO_PROJECT_NAME=
ADO_PAT=
ADO_ASSIGNED_TO=

# Microsoft Teams incoming webhook URL
TEAMS_WEBHOOK=

# Microsoft Purview account name
PURVIEW_ACCOUNT_NAME=
