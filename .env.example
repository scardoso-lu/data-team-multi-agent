# ── Azure DevOps ──────────────────────────────────────────────────────────────
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PAT=your-personal-access-token          # Scopes: Work Items (RW), Code (RW), Wiki (RW)
ADO_PROJECT=YourProject
ADO_REPO_NAME=data-platform
ADO_WIKI_ID=YourProject.wiki

# Board column names must match your ADO board exactly
COL_ARCHITECTURE=01 - Architecture
COL_ENGINEERING=02 - Engineering
COL_QA=03 - QA & Testing
COL_ANALYTICS=04 - Analytics & BI
COL_GOVERNANCE=05 - Governance & Review
COL_DONE=Done

# ── Microsoft Entra ID (formerly Azure AD) ────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id          # App registration with Graph + Fabric permissions
AZURE_CLIENT_SECRET=your-client-secret

# ── Microsoft Teams (via Microsoft Graph) ────────────────────────────────────
TEAMS_TEAM_ID=your-teams-team-id
TEAMS_CHANNEL_ID=your-teams-channel-id
# Public HTTPS URL that Teams posts Adaptive Card approval responses to.
# In production: Azure Function URL.  In dev: use ngrok or Azure Dev Tunnels.
APPROVAL_WEBHOOK_URL=https://your-host/webhook/approve

# ── Microsoft Fabric ──────────────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=your-fabric-workspace-guid
# Lakehouse item IDs per medallion layer (created manually or by architect agent)
FABRIC_BRONZE_LAKEHOUSE_ID=guid
FABRIC_SILVER_LAKEHOUSE_ID=guid
FABRIC_GOLD_LAKEHOUSE_ID=guid

# ── Microsoft Purview ─────────────────────────────────────────────────────────
PURVIEW_ENDPOINT=https://your-account.purview.azure.com
PURVIEW_COLLECTION=root-collection-name

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# ── Orchestrator behaviour ────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30
APPROVAL_TIMEOUT_HOURS=24
BOT_DISPLAY_NAME=Data Team Agent Bot
